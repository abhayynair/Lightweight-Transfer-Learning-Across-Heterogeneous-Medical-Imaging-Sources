2D(128,3,padding='same',activation='relu'), BatchNormalization(),\n        Conv2D(128,3,padding='same',activation='relu'), BatchNormalization(),\n        MaxPooling2D(), Dropout(0.25),\n        GlobalAveragePooling2D(),\n        Dense(256,activation='relu'), Dropout(0.5),\n        Dense(num_classes,activation='softmax')\n    ])\n    return m\n\n# ===== CELL 3b: PRETRAINED BUILDER (backbone nested -> Grad-CAM friendly) =====\ndef build_pretrained(base_class, num_classes=6, shape=(224,224,3)):\n    base = base_class(include_top=False, weights='imagenet', input_shape=shape)\n    model = Sequential([\n        base,\n        GlobalAveragePooling2D(),\n        Dense(256,activation='relu'),\n        Dropout(0.3),\n        Dense(num_classes,activation='softmax')\n    ])\n    return model, base       # return base so we can toggle base.trainable for the two phases\n\nprint(build_custom_cnn().count_params(), \"custom params (record this as new canonical)\")","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# ===== TRAINING TEMPLATE, CUSTOM CNN (Stage 4) =====\nmodel = build_custom_cnn()\ntr, va, te = make_gens(None)                         # rescale 1./255 path\nmodel.compile(Adam(1e-3), 'categorical_crossentropy', ['accuracy'])\ncbs = [EarlyStopping(monitor='val_accuracy', patience=7, restore_best_weights=True),\n       ModelCheckpoint(f'/kaggle/working/{W_CUSTOM}', monitor='val_accuracy', save_best_only=True),\n       CSVLogger('/kaggle/working/custom_log.csv')]\nmodel.fit(tr, validation_data=va, epochs=60, class_weight=CLASS_WEIGHT, callbacks=cbs, verbose=1)\nprint(\"TEST:\", model.evaluate(te, verbose=0))","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# ===== FIX-A: bake balanced class weights into a per-row sample_weight column =====\n# Same weights as Cell 2b (cw array, FINAL_CLASSES order), just applied per-row\n# instead of passed as class_weight to fit(), to route around th